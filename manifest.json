{
  "name": "Mathix — AI Scientific Calculator",
  "short_name": "Mathix",
  "description": "Free AI-powered scientific calculator with step-by-step solutions, graphing, solver, and photo math scanner.",
  "start_url": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "background_color": "#04040d",
  "theme_color": "#04040d",
  "orientation": "any",
  "scope": "/",
  "lang": "en",
  "categories": ["education", "productivity", "utilities"],
  "icons": [
    { "src": "/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any maskable" },
    { "src": "/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any maskable" }
  ],
  "shortcuts": [
    { "name": "Calculator",     "short_name": "Calc",   "description": "Open the scientific calculator", "url": "/?tab=calc",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }] },
    { "name": "Solver",         "short_name": "Solver", "description": "Open the equation solver",       "url": "/?tab=solver",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }] },
    { "name": "Photo Scanner",  "short_name": "Scan",   "description": "Scan a math problem",            "url": "/?tab=scan",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }] },
    { "name": "Graphing",       "short_name": "Graph",  "description": "Open the grapher",                "url": "/?tab=graph",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }] }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        { "name": "image",  "accept": ["image/png", "image/jpeg", "image/webp"] },
        { "name": "photos", "accept": ["image/*"] }
      ]
    }
  }
}
